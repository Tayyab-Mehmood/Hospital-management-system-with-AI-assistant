    .lp-about-feat { font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.9); padding: 8px 12px; background: rgba(255,255,255,0.07); border-radius: 8px; }
    .lp-contact-card { background: var(--lp-white); border: 1px solid var(--lp-border); border-radius: var(--lp-radius); padding: 28px 24px; text-align: center; transition: all 0.3s ease; }
    .lp-contact-card:hover { box-shadow: 0 12px 30px rgba(43,191,179,0.15); border-color: var(--lp-teal); transform: translateY(-4px); }
    .lp-contact-icon { width: 52px; height: 52px; background: var(--lp-teal-light); color: var(--lp-teal); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; margin: 0 auto 16px; }
    .lp-contact-title { font-weight: 700; color: var(--lp-navy); margin-bottom: 6px; }
    .lp-contact-text { font-size: 14px; color: var(--lp-muted); margin: 0; line-height: 1.6; }
    .lp-footer { background: var(--lp-navy); padding: 48px 0 24px; }
    .lp-footer-brand { font-size: 18px; font-weight: 800; color: #fff; letter-spacing: -0.3px; }
    .lp-footer-text { font-size: 13.5px; color: rgba(255,255,255,0.5); max-width: 320px; line-height: 1.6; margin: 0; }
    .lp-footer-links-heading { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 12px; }
    .lp-footer-links { list-style: none; padding: 0; margin: 0; }
    .lp-footer-links li { margin-bottom: 8px; }
    .lp-footer-links a { font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none; transition: color 0.2s; }
    .lp-footer-links a:hover { color: var(--lp-teal); }
    .lp-footer-hr { border-color: rgba(255,255,255,0.1); margin: 32px 0 16px; }
    .lp-footer-copy { font-size: 13px; color: rgba(255,255,255,0.35); }
    .lp-chatbot-btn { position: fixed; bottom: 28px; right: 28px; width: 58px; height: 58px; background: var(--lp-teal); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; color: #fff; cursor: pointer; z-index: 1000; box-shadow: 0 8px 24px rgba(43,191,179,0.5); transition: all 0.3s ease; user-select: none; }
    .lp-chatbot-btn:hover { transform: scale(1.08); box-shadow: 0 12px 30px rgba(43,191,179,0.6); }
    .lp-chatbot-active { background: #E11D48; box-shadow: 0 8px 24px rgba(225,29,72,0.4); }
    .lp-chat-ping { position: absolute; top: 10px; right: 10px; width: 10px; height: 10px; background: #FCD34D; border-radius: 50%; border: 2px solid #fff; animation: lp-ping 1.5s infinite; }
    @@keyframes lp-ping { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.3); opacity: 0.7; } }
    .lp-chat-panel { position: fixed; bottom: 100px; right: 28px; width: 360px; background: #fff; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); z-index: 999; overflow: hidden; display: flex; flex-direction: column; max-height: 520px; animation: lp-chat-in 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes lp-chat-in { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .lp-chat-header { background: linear-gradient(135deg, var(--lp-navy), var(--lp-navy-mid)); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .lp-chat-avatar { width: 40px; height: 40px; background: rgba(43,191,179,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--lp-teal); }
    .lp-chat-title { font-size: 15px; font-weight: 700; color: #fff; }
    .lp-chat-status { font-size: 11px; color: rgba(255,255,255,0.55); display: flex; align-items: center; gap: 5px; }
    .lp-chat-close { background: transparent; border: none; color: rgba(255,255,255,0.5); font-size: 14px; cursor: pointer; transition: color 0.2s; padding: 4px; }
    .lp-chat-close:hover { color: #fff; }
    .lp-chat-body { padding: 16px; flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; }
    .lp-chat-msg { display: flex; flex-direction: column; }
    .lp-bot-msg { align-items: flex-start; }
    .lp-user-msg { align-items: flex-end; }
    .lp-msg-bubble { max-width: 88%; font-size: 13.5px; line-height: 1.6; padding: 10px 14px; border-radius: 16px; word-break: break-word; }
    .lp-msg-bot { background: #F4F6F9; color: var(--lp-navy); border-radius: 4px 16px 16px 16px; }
    .lp-msg-user { background: var(--lp-teal); color: #fff; border-radius: 16px 4px 16px 16px; }
    .lp-msg-error { background: #FFF0F2; color: #C8102E; border-radius: 4px 16px 16px 16px; font-size: 13px; }
    .lp-typing-indicator { display: flex; gap: 4px; padding: 10px 14px; background: #F4F6F9; border-radius: 4px 16px 16px 16px; width: fit-content; }
    .lp-typing-indicator span { width: 7px; height: 7px; border-radius: 50%; background: #9CA3AF; animation: lp-typing 1.2s infinite; }
    .lp-typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .lp-typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes lp-typing { 0%, 100% { transform: translateY(0); opacity: 0.5; } 50% { transform: translateY(-4px); opacity: 1; } }
    .lp-chat-footer { padding: 12px 14px; border-top: 1px solid var(--lp-border); display: flex; gap: 8px; flex-shrink: 0; background: #fff; }
    .lp-chat-input { flex: 1; border: 1.5px solid var(--lp-border); border-radius: 10px; padding: 9px 14px; font-size: 13px; background: #F9FAFB; color: #1A1A2E; outline: none; transition: border-color 0.2s; }
    .lp-chat-input:focus { border-color: var(--lp-teal); background: #fff; }
    .lp-chat-input:disabled { opacity: 0.6; cursor: not-allowed; }
    .lp-chat-send { width: 38px; height: 38px; background: var(--lp-teal); border: none; border-radius: 10px; color: #fff; font-size: 14px; cursor: pointer; transition: all 0.2s; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
    .lp-chat-send:hover:not(:disabled) { background: var(--lp-teal-dark); transform: scale(1.05); }
    .lp-send-disabled { opacity: 0.4; cursor: not-allowed; }
    /* Booking confirmation cards */
    .lp-booking-card { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; border-radius: 12px; margin-top: 6px; max-width: 90%; }
    .lp-booking-success { background: #ECFDF5; border: 1px solid #A7F3D0; }
    .lp-booking-fail { background: #FFF0F0; border: 1px solid #FECACA; }
    .lp-booking-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    @@media (max-width: 767px) {
        .lp-hero { padding-top: 80px; padding-bottom: 60px; }
        .lp-section { padding: 60px 0; }
        .lp-chat-panel { width: calc(100vw - 24px); right: 12px; bottom: 90px; max-height: 460px; }
        .lp-chatbot-btn { bottom: 20px; right: 20px; width: 52px; height: 52px; font-size: 20px; }
    }
    .lp-chat-body::-webkit-scrollbar { width: 4px; }
    .lp-chat-body::-webkit-scrollbar-track { background: transparent; }
    .lp-chat-body::-webkit-scrollbar-thumb { background: #E5E7EB; border-radius: 4px; }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

@code {
    // ── Page state ─────────────────────────────────────────────────────────
    private bool chatOpen = false;
    private List<DoctorDto>? landingDoctors;
    private string doctorSearch = "";
    private string doctorDeptFilter = "";

    // ── Chat state ──────────────────────────────────────────────────────────
    private List<ChatMessage> chatMessages = new();
    private string chatInput = "";
    private bool isBotTyping = false;
    private string chatError = "";

    // Each entry is a plain { role, content } pair — matches what the API expects
    // Plain class instead of record — avoids Razor parser treating () as expression
    private class HistoryEntry
    {
        public string role    { get; init; }
        public string content { get; init; }
        public HistoryEntry(string r, string c) { role = r; content = c; }
    }
    private List<HistoryEntry> conversationHistory = new();

    private class ChatMessage
    {
        public string                   Text    { get; init; }
        public bool                     IsUser  { get; init; }
        public AppointmentBookingResult? Booking { get; init; }
        public ChatMessage(string text, bool isUser, AppointmentBookingResult? booking = null)
        {
            Text    = text;
            IsUser  = isUser;
            Booking = booking;
        }
    }

    private IEnumerable<DoctorDto> FilteredLandingDoctors =>
        landingDoctors?.Where(d =>
            (string.IsNullOrWhiteSpace(doctorSearch) ||
             $"{d.FirstName} {d.LastName} {d.Specialization}".Contains(doctorSearch, StringComparison.OrdinalIgnoreCase))
            &&
            (string.IsNullOrWhiteSpace(doctorDeptFilter) || d.DepartmentName == doctorDeptFilter)
        ) ?? Enumerable.Empty<DoctorDto>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StateProvider.TryRestoreSessionAsync();
            StateHasChanged();

            _ = LoadDoctorsAsync();

            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    var navbar = document.getElementById('lp-navbar');
                    if (!navbar) return;
                    window.addEventListener('scroll', function() {
                        if (window.scrollY > 20) navbar.classList.add('lp-scrolled');
                        else navbar.classList.remove('lp-scrolled');
                    });
                    var navLinks = document.querySelectorAll('.lp-nav-link');
                    var sections = ['home', 'services', 'doctors', 'about', 'contact'];
                    window.addEventListener('scroll', function() {
                        var scrollPos = window.scrollY + 100;
                        sections.forEach(function(id) {
                            var el = document.getElementById(id);
                            if (!el) return;
                            if (el.offsetTop <= scrollPos && el.offsetTop + el.offsetHeight > scrollPos) {
                                navLinks.forEach(function(l) { l.classList.remove('active'); });
                                var active = document.querySelector('.lp-nav-link[href=""#' + id + '""]');
                                if (active) active.classList.add('active');
                            }
                        });
                    });
                })();
            ");
        }

        // Auto-scroll chat to bottom whenever messages change
        if (chatOpen && (chatMessages.Any() || isBotTyping))
        {
            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    var el = document.getElementById('lp-chat-body');
                    if (el) el.scrollTop = el.scrollHeight;
                })();
            ");
        }
    }

    private async Task LoadDoctorsAsync()
    {
        try
        {
            landingDoctors = await Http.GetFromJsonAsync<List<DoctorDto>>("api/Patient/available-doctors");
        }
        catch
        {
            landingDoctors = new List<DoctorDto>();
        }
        await InvokeAsync(StateHasChanged);
    }

    private string GetShortSchedule(string scheduleDays)
    {
        if (string.IsNullOrWhiteSpace(scheduleDays)) return "—";
        var days = scheduleDays.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (days.Length == 0) return "—";
        var shorts = days.Select(d => d.Length >= 3 ? d[..3] : d).ToList();
        if (shorts.Count == 1) return shorts[0];
        return $"{shorts.First()}–{shorts.Last()}";
    }

    private void HandleBookAppointmentClick()
    {
        if (StateProvider.IsAuthenticated && StateProvider.Role == "Patient")
            Nav.NavigateTo("/patient/appointments");
        else
            Nav.NavigateTo("/login");
    }

    private void ToggleChat()
    {
        chatOpen = !chatOpen;
        if (chatOpen)
        {
            chatError = "";
            // Don't clear history on open — user may reopen mid-conversation
        }
    }

    // ── Chat: handle Enter key ──────────────────────────────────────────────
    private async Task HandleChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isBotTyping && !string.IsNullOrWhiteSpace(chatInput))
            await SendChatMessage();
    }

    // ── Chat: send a message ────────────────────────────────────────────────
    private async Task SendChatMessage()
    {
        var question = chatInput.Trim();
        if (string.IsNullOrWhiteSpace(question) || isBotTyping) return;

        chatInput = "";
        chatError = "";
        chatMessages.Add(new ChatMessage(question, true));
        isBotTyping = true;
        StateHasChanged();

        try
        {
            var payload = new
            {
                question,
                patientId         = StateProvider.IsAuthenticated && StateProvider.Role == "Patient" ? StateProvider.UserId : 0,
                patientName       = StateProvider.IsAuthenticated && StateProvider.Role == "Patient" ? StateProvider.FullName : "",
                isPatientLoggedIn = StateProvider.IsAuthenticated && StateProvider.Role == "Patient",
                history           = conversationHistory
            };

            var response = await Http.PostAsJsonAsync("api/Chatbot/ask", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatbotResponseDto>();
                if (result != null)
                {
                    // Store both turns in history so the AI has full context next message
                    conversationHistory.Add(new HistoryEntry("user",      question));
                    conversationHistory.Add(new HistoryEntry("assistant", result.Answer ?? ""));

                    // Cap history at 20 messages to avoid token limits
                    if (conversationHistory.Count > 20)
                        conversationHistory = conversationHistory
                            .Skip(conversationHistory.Count - 20).ToList();

                    if (!string.IsNullOrWhiteSpace(result.Answer))
                        chatMessages.Add(new ChatMessage(result.Answer, false, result.BookingResult));
                    else if (result.BookingResult != null)
                        chatMessages.Add(new ChatMessage("", false, result.BookingResult));

                    // Clear history after a successful booking so next booking starts fresh
                    if (result.BookingResult?.Success == true)
                        conversationHistory.Clear();
                }
            }
            else
            {
                var errText = await response.Content.ReadAsStringAsync();
                chatError = string.IsNullOrWhiteSpace(errText)
                    ? "Something went wrong. Please try again."
                    : errText.Length > 160 ? errText[..160] + "…" : errText;
            }
        }
        catch (Exception ex)
        {
            chatError = "Could not reach the server: " + ex.Message;
        }
        finally
        {
            isBotTyping = false;
            StateHasChanged();
        }
    }

    // ── Format bot message: convert **bold**, bullet points, newlines to HTML ──
    private static string FormatBotMessage(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return text;

        // Escape HTML first
        text = System.Net.WebUtility.HtmlEncode(text);

        // Convert **text** → <strong>text</strong>
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");

        // Convert *text* → <em>text</em>  (only single asterisks not already handled)
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)", "<em>$1</em>");

        // Convert bullet lines: "- item" or "• item" → proper list items
        var lines = text.Split('\n');
        var result = new System.Text.StringBuilder();
        bool inList = false;
        foreach (var line in lines)
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("- ") || trimmed.StartsWith("• "))
            {
                if (!inList) { result.Append("<ul style='margin:6px 0 6px 14px;padding:0;'>"); inList = true; }
                result.Append($"<li style='margin-bottom:3px;'>{trimmed[2..]}</li>");
            }
            else
            {
                if (inList) { result.Append("</ul>"); inList = false; }
                if (!string.IsNullOrWhiteSpace(trimmed))
                    result.Append(trimmed + "<br/>");
                else
                    result.Append("<br/>");
            }
        }
        if (inList) result.Append("</ul>");
        return result.ToString().TrimEnd("<br/>".ToCharArray());
    }

    private void OpenMedibot()
    {
        chatOpen = true;
        chatError = "";
        StateHasChanged();
    }

    /// <summary>
    /// Routes service card clicks based on the logged-in role.
    /// service: "patient-management" | "appointments" | "billing" | "prescriptions" | "admin-dashboard"
    /// </summary>
    private void NavigateService(string service)
    {
        var role = StateProvider.IsAuthenticated ? StateProvider.Role : "";

        switch (service)
        {
            case "patient-management":
                if      (role == "Patient") Nav.NavigateTo("/patient/dashboard");
                else if (role == "Admin")   Nav.NavigateTo("/admin/patients");
                else if (role == "Doctor")  Nav.NavigateTo("/doctor/portal");
                else                        Nav.NavigateTo("/login");
                break;

            case "appointments":
                if      (role == "Patient") Nav.NavigateTo("/patient/appointments");
                else if (role == "Admin")   Nav.NavigateTo("/");          // admin dashboard shows appointments
                else if (role == "Doctor")  Nav.NavigateTo("/doctor/portal");
                else                        Nav.NavigateTo("/login");
                break;

            case "billing":
                if      (role == "Patient") Nav.NavigateTo("/patient/billing");
                else if (role == "Admin")   Nav.NavigateTo("/admin/checkouts");
                else if (role == "Doctor")  Nav.NavigateTo("/doctor/portal");
                else                        Nav.NavigateTo("/login");
                break;

            case "prescriptions":
                if      (role == "Patient") Nav.NavigateTo("/patient/prescriptions");
                else if (role == "Admin")   Nav.NavigateTo("/admin/patients");   // prescriptions live under patients in admin
                else if (role == "Doctor")  Nav.NavigateTo("/doctor/portal");
                else                        Nav.NavigateTo("/login");
                break;

            case "admin-dashboard":
                if      (role == "Admin")   Nav.NavigateTo("/");
                else                        Nav.NavigateTo("/login");   // patients and doctors → login
                break;

            default:
                Nav.NavigateTo("/login");
                break;
        }
    }

    private void SmartNavigate(string defaultPath)
    {
        if (StateProvider.IsAuthenticated)
            GoToMyPortal();
        else
            Nav.NavigateTo(defaultPath);
    }

    private void GoToMyPortal()
    {
        if (StateProvider.Role == "Admin")        Nav.NavigateTo("/");
        else if (StateProvider.Role == "Doctor")  Nav.NavigateTo("/doctor/portal");
        else if (StateProvider.Role == "Patient") Nav.NavigateTo("/patient/dashboard");
    }

    private void HandleLogout()
    {
        StateProvider.MarkUserAsLoggedOut();
        Nav.NavigateTo("/landing", forceLoad: true);
    }

    private async Task ScrollTo(string sectionId)
    {
        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                var el = document.getElementById('{sectionId}');
                if (el) {{
                    var offset = 72;
                    var top = el.getBoundingClientRect().top + window.pageYOffset - offset;
                    window.scrollTo({{ top: top, behavior: 'smooth' }});
                }}
            }})();
        ");
    }
}
