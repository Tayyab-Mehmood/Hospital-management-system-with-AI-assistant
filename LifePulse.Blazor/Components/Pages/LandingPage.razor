    .lp-about-img { position: relative; width: 100%; height: 380px; object-fit: cover; border-radius: 16px; box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
    .lp-about-badge { position: absolute; bottom: -12px; right: -10px; background: #fff; border-radius: 12px; padding: 10px 18px; font-size: 13px; font-weight: 600; color: var(--lp-navy); box-shadow: 0 8px 24px rgba(0,0,0,0.15); display: flex; align-items: center; }
