    .lp-doc-card-skeleton { pointer-events: none; }
    .lp-skel { background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%); background-size: 200% 100%; animation: lp-shimmer 1.4s infinite; border-radius: 8px; }
    @@keyframes lp-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .lp-skel-avatar { width: 60px; height: 60px; border-radius: 50%; }
    .lp-skel-line { height: 14px; width: 80%; }
    .lp-skel-lg { width: 60%; height: 16px; }
    .lp-skel-sm { width: 40%; height: 12px; }
    .lp-skel-btn { height: 38px; width: 100%; border-radius: 10px; }
