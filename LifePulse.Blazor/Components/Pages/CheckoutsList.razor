@page "/admin/checkouts"
@using LifePulse.Shared
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Billing | LifePulse</PageTitle>

<div class="container-fluid px-2 px-md-4">

    <!-- Page Header with Back Button -->
    <div class="mb-4 no-print">
        <h1 style="font-size: clamp(20px,5vw,26px); font-weight: 700; color: #1A1A2E; margin: 0;">Billing & Checkout Accounting</h1>
            <p style="font-size: 14px; color: #6B7280; margin: 2px 0 0 0;">
                Process discharge financial invoice items and track account clearing parameters.
            </p>
    </div>

    <!-- Generate Bill Form -->
    <div class="mb-4 no-print text-dark" style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
        <h5 style="font-size: 15px; font-weight: 600; color: #1A1A2E; margin-bottom: 16px;">
            <i class="bi bi-calculator me-2" style="color: #2BBFB3;"></i>Generate Patient Discharge Bill
        </h5>

        <!-- Info: only patients with appointments -->
        <div class="mb-3 p-3 d-flex align-items-start gap-2"
             style="background-color: #EFF6FF; border-radius: 8px; border-left: 3px solid #2BBFB3; font-size: 13px; color: #1D4ED8;">
            <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px;"></i>
            <span>Only patients who have booked at least one appointment can be invoiced.</span>
        </div>

        <EditForm Model="newCheckout" OnValidSubmit="HandleProcessCheckout">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="field-label">Patient Beneficiary</label>
                    <select class="form-select lp-input text-dark" @bind="newCheckout.PatientId" required>
                        <option value="0">-- Assign Registered Patient --</option>
                        @if (patientsWithAppointments != null)
                        {
                            @foreach (var p in patientsWithAppointments)
                            {
                                <option value="@p.PatientId">@p.FirstName @p.LastName</option>
                            }
                        }
                    </select>
                    @if (patients != null && patientsWithAppointments != null && patients.Count > patientsWithAppointments.Count)
                    {
                        <small style="color:#9CA3AF;font-size:11px;">
                            @(patients.Count - patientsWithAppointments.Count) patient(s) hidden — no appointments yet.
                        </small>
                    }
                </div>
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="field-label">Total Amount ($)</label>
                    <input type="number" step="0.01" class="form-control lp-input text-dark"
                           placeholder="e.g. 150.00" @bind-value="newCheckout.TotalAmount" required />
                </div>
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="field-label">Payment Status</label>
                    <select class="form-select lp-input text-dark" @bind="newCheckout.PaymentStatus" required>
                        <option value="Unpaid">Unpaid</option>
                        <option value="Paid">Paid / Cleared</option>
                    </select>
                </div>
                <div class="col-12 col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn fw-semibold w-100"
                            style="background-color: #2BBFB3; color: #FFFFFF; border-radius: 8px; padding: 10px 14px; border: none;"
                            disabled="@(newCheckout.PatientId == 0)">
                        <i class="bi bi-receipt me-1"></i>Issue Invoice
                    </button>
                </div>
                <div class="col-12">
                    <label class="field-label">Audit Remarks / Treatment Notes</label>
                    <input type="text" class="form-control lp-input text-dark"
                           placeholder="e.g. consultation fee, lab tests, room charges..."
                           @bind-value="newCheckout.Notes" />
                </div>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(formMessage))
        {
            <div class="mt-3 p-2" style="background-color: @(formSuccess ? "#D1FAF5" : "#FFE4E6"); color: @(formSuccess ? "#0D9488" : "#E11D48"); border-radius: 8px; font-size: 13px; font-weight: 500;">
                <i class="bi @(formSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>@formMessage
            </div>
        }
    </div>

    <!-- Billing Table -->
    <div style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">

        <div class="row g-3 justify-content-between align-items-center mb-4 no-print">
            <div class="col-12 col-sm-6 col-md-5" style="position: relative;">
                <input type="text" class="form-control text-dark"
                       style="background-color: #F3F4F6; border: none; border-radius: 24px; padding: 10px 18px 10px 40px;"
                       placeholder="Search by patient name..."
                       @bind="checkoutSearchQuery" @bind:event="oninput" />
                <i class="bi bi-search" style="position: absolute; left: 24px; top: 12px; color: #9CA3AF;"></i>
            </div>
            <div class="col-12 col-sm-auto text-sm-end">
                <button class="btn fw-semibold w-100"
                        style="border: 1px solid #2BBFB3; color: #2BBFB3; background: #FFFFFF; border-radius: 20px; padding: 6px 16px; font-size: 13px;"
                        @onclick="PrintCheckoutReport">
                    <i class="bi bi-printer me-1"></i> Print Audit Report
                </button>
            </div>
        </div>

        <!-- Print Header -->
        <div class="print-only mb-4 text-center border-bottom pb-3">
            <h3 style="color: #1A1A2E; font-weight: 700; margin: 0;">LIFEPULSE CLINICAL HEALTHCARE NETWORK</h3>
            <p style="color: #6B7280; margin: 4px 0 0 0; font-size: 14px; font-weight: 600;">Financial Checkout Accounting & Discharge Log Audit Statement</p>
            <small style="color: #9CA3AF;">Generated: @DateTime.Now.ToString("g")</small>
        </div>

        @if (filteredCheckouts == null)
        {
            <div class="text-center py-4"><div class="spinner-border" style="color: #2BBFB3;" role="status"></div></div>
        }
        else if (!filteredCheckouts.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-receipt-cutoff" style="font-size: 48px; color: #D1D5DB;"></i>
                <p style="color: #6B7280; font-size: 14px; margin-top: 12px;">No billing records found.</p>
            </div>
        }
        else
        {
            <!-- Summary row -->
            <div class="d-flex gap-3 mb-3 flex-wrap no-print">
                <span style="font-size: 13px; font-weight: 600; background-color: #FEE2E2; color: #E11D48; padding: 4px 14px; border-radius: 20px;">
                    Unpaid: @checkouts!.Count(c => c.PaymentStatus == "Unpaid")
                </span>
                <span style="font-size: 13px; font-weight: 600; background-color: #D1FAF5; color: #0D9488; padding: 4px 14px; border-radius: 20px;">
                    Paid: @checkouts!.Count(c => c.PaymentStatus == "Paid")
                </span>
                <span style="font-size: 13px; font-weight: 600; background-color: #F3F4F6; color: #1A1A2E; padding: 4px 14px; border-radius: 20px;">
                    Total: $@checkouts!.Sum(c => c.TotalAmount).ToString("N2")
                </span>
            </div>

            <div class="table-responsive">
                <table class="table align-middle m-0" style="width: 100%; min-width: 600px;">
                    <thead>
                        <tr style="background-color: #F9FAFB; border-bottom: 2px solid #F3F4F6;">
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Patient</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Issue Date</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Amount</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px; text-align: center;">Status</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Remarks</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px; text-align: center;" class="no-print">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in filteredCheckouts)
                        {
                            bool isPaid = bill.PaymentStatus == "Paid";
                            <tr style="border-bottom: 1px solid #F3F4F6;">
                                <td style="font-size: 14px; font-weight: 700; color: #1A1A2E; padding: 14px 12px;">@bill.PatientFullName</td>
                                <td style="font-size: 13px; color: #6B7280; padding: 14px 12px;">
                                    @bill.CheckoutDate.ToString("dd MMM yyyy")
                                    <div style="font-size: 11px;">@bill.CheckoutDate.ToString("HH:mm")</div>
                                </td>
                                <td style="font-size: 15px; font-weight: 700; color: #0D9488; padding: 14px 12px;">$@bill.TotalAmount.ToString("F2")</td>
                                <td style="padding: 14px 12px; text-align: center;">
                                    @if (isPaid)
                                    {
                                        <span style="font-size: 12px; font-weight: 600; background-color: #D1FAF5; color: #0D9488; padding: 4px 14px; border-radius: 20px; white-space:nowrap;">Paid</span>
                                    }
                                    else
                                    {
                                        <span style="font-size: 12px; font-weight: 600; background-color: #FFE4E6; color: #E11D48; padding: 4px 14px; border-radius: 20px; white-space:nowrap;">Unpaid</span>
                                    }
                                </td>
                                <td style="font-size: 13px; color: #6B7280; padding: 14px 12px; max-width: 220px;">
                                    @(string.IsNullOrWhiteSpace(bill.Notes) ? "—" : bill.Notes)
                                </td>
                                <td style="padding: 14px 12px; text-align: center;" class="no-print">
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        <button class="btn btn-sm fw-semibold px-3"
                                                style="border: 1px solid #2BBFB3; color: #2BBFB3; background: #FFFFFF; border-radius: 6px; font-size: 12px;"
                                                @onclick="() => OpenBillEditModal(bill)">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm fw-semibold px-3"
                                                style="background-color: #FFE4E6; color: #E11D48; border-radius: 6px; border: none; font-size: 12px;"
                                                @onclick="() => DeleteBill(bill.CheckoutId)">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Edit Bill Modal *@
@if (isBillEditModalOpen)
{
    <div class="no-print" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:2000;padding:16px;">
        <div class="text-dark" style="background-color:#FFFFFF;border-radius:14px;padding:28px;box-shadow:0 8px 32px rgba(0,0,0,0.18);width:100%;max-width:500px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 style="font-size:16px;font-weight:700;color:#1A1A2E;margin:0;">
                    <i class="bi bi-pencil-square me-2" style="color:#2BBFB3;"></i>Update Invoice
                </h5>
                <button class="btn p-1" style="border:none;background:transparent;" @onclick="CloseBillEditModal">
                    <i class="bi bi-x-lg" style="font-size:18px;color:#6B7280;"></i>
                </button>
            </div>
            <div class="mb-3 p-3" style="background-color:#F4F6F9;border-radius:8px;">
                <div style="font-size:12px;color:#9CA3AF;">Patient</div>
                <div style="font-size:14px;font-weight:700;color:#1A1A2E;">@editingCheckout.PatientFullName</div>
            </div>
            <EditForm Model="editingCheckout" OnValidSubmit="HandleUpdateBill">
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="field-label">Amount ($)</label>
                        <input type="number" step="0.01" class="form-control lp-input text-dark" @bind-value="editingCheckout.TotalAmount" required />
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="field-label">Payment Status</label>
                        <select class="form-select lp-input text-dark" @bind="editingCheckout.PaymentStatus" required>
                            <option value="Unpaid">Unpaid</option>
                            <option value="Paid">Paid / Cleared</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="field-label">Audit Remarks</label>
                        <input type="text" class="form-control lp-input text-dark" @bind-value="editingCheckout.Notes" />
                    </div>
                    <div class="col-12 d-flex gap-2 justify-content-end mt-2">
                        <button type="button" class="btn fw-semibold px-4"
                                style="border:1px solid #E6EAF0;color:#6B7280;background:#FFFFFF;border-radius:8px;"
                                @onclick="CloseBillEditModal">Cancel</button>
                        <button type="submit" class="btn fw-semibold px-4"
                                style="background-color:#2BBFB3;color:#FFFFFF;border-radius:8px;border:none;">
                            Save Changes
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .field-label { font-size: 12px; color: #6B7280; font-weight: 600; margin-bottom: 4px; display: block; }
    .lp-input { background-color: #F9FAFB; border: 1px solid #E6EAF0; border-radius: 8px; padding: 10px 14px; }
    .print-only { display: none; }
    @@media print {
        .no-print { display: none !important; visibility: hidden !important; }
        body, html, main, .content { background: #FFFFFF !important; color: #000000 !important; margin: 0 !important; padding: 0 !important; }
        .print-only { display: block !important; }
        table { width: 100% !important; border-collapse: collapse !important; }
        th { background-color: #F3F4F6 !important; color: #000000 !important; border: 1px solid #DDDDDD !important; padding: 8px !important; }
        td { background: #FFFFFF !important; color: #000000 !important; border: 1px solid #DDDDDD !important; padding: 8px !important; }
    }
</style>

@code {
    private List<CheckoutDto>? checkouts;
    private List<PatientDto>? patients;
    private List<PatientDto>? patientsWithAppointments;  // Only patients who have appointments
    private CheckoutDto newCheckout = new() { PaymentStatus = "Unpaid", PatientId = 0 };
    private CheckoutDto editingCheckout = new();
    private string checkoutSearchQuery = "";
    private bool isBillEditModalOpen = false;
    private string formMessage = "";
    private bool formSuccess = false;

    protected override async Task OnInitializedAsync() => await LoadAccountingData();

    private async Task LoadAccountingData()
    {
        checkouts = await Http.GetFromJsonAsync<List<CheckoutDto>>("api/Admin/checkouts");
        patients  = await Http.GetFromJsonAsync<List<PatientDto>>("api/Admin/patients");

        // Only show patients with at least one appointment in the dropdown
        var appointments = await Http.GetFromJsonAsync<List<AppointmentDto>>("api/Admin/appointments");
        var patientIdsWithAppts = appointments?
            .Select(a => a.PatientId)
            .Distinct()
            .ToHashSet() ?? new HashSet<int>();

        patientsWithAppointments = patients?
            .Where(p => patientIdsWithAppts.Contains(p.PatientId))
            .ToList() ?? new List<PatientDto>();
    }

    private IEnumerable<CheckoutDto>? filteredCheckouts =>
        string.IsNullOrWhiteSpace(checkoutSearchQuery) ? checkouts :
        checkouts?.Where(c => (c.PatientFullName ?? "").Contains(checkoutSearchQuery, StringComparison.OrdinalIgnoreCase));

    private async Task HandleProcessCheckout()
    {
        formMessage = "";
        var response = await Http.PostAsJsonAsync("api/Admin/checkouts", newCheckout);
        if (response.IsSuccessStatusCode)
        {
            formSuccess = true;
            formMessage = "Invoice issued successfully.";
            newCheckout = new() { PaymentStatus = "Unpaid", PatientId = 0 };
            await LoadAccountingData();
        }
        else
        {
            formSuccess = false;
            formMessage = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(formMessage))
                formMessage = "Failed to issue invoice. Please try again.";
        }
    }

    private void OpenBillEditModal(CheckoutDto bill)
    {
        editingCheckout = new CheckoutDto
        {
            CheckoutId = bill.CheckoutId, PatientId = bill.PatientId,
            PatientFullName = bill.PatientFullName, TotalAmount = bill.TotalAmount,
            PaymentStatus = bill.PaymentStatus, Notes = bill.Notes, CheckoutDate = bill.CheckoutDate
        };
        isBillEditModalOpen = true;
    }

    private void CloseBillEditModal() => isBillEditModalOpen = false;

    private async Task HandleUpdateBill()
    {
        var response = await Http.PutAsJsonAsync($"api/Admin/checkouts/{editingCheckout.CheckoutId}", editingCheckout);
        if (response.IsSuccessStatusCode) { isBillEditModalOpen = false; await LoadAccountingData(); }
    }

    private async Task DeleteBill(int id)
    {
        var response = await Http.DeleteAsync($"api/Admin/checkouts/{id}");
        if (response.IsSuccessStatusCode) await LoadAccountingData();
    }

    private async Task PrintCheckoutReport() => await JS.InvokeVoidAsync("window.print");
}
