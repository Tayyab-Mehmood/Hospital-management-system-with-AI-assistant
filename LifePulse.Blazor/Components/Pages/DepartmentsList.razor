@page "/admin/departments"
@using LifePulse.Shared
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Departments | LifePulse</PageTitle>

<div class="container-fluid px-2 px-md-4">

    <!-- Page Header -->
    <div class="mb-4">
        <h1 style="font-size: clamp(20px,5vw,26px); font-weight: 700; color: #1A1A2E; margin: 0;">Hospital Departments</h1>
        <p style="font-size: 14px; color: #6B7280; margin: 2px 0 0 0;">
            Configure clinical structural units and specialties blocks inside the medical core network.
        </p>
    </div>

    <!-- Create Department Form -->
    <div class="mb-4 text-dark" style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
        <h5 style="font-size: 15px; font-weight: 600; color: #1A1A2E; margin-bottom: 16px;">
            <i class="bi bi-plus-circle-fill me-2" style="color: #2BBFB3;"></i>Create New Department
        </h5>
        <EditForm Model="newDepartment" OnValidSubmit="HandleCreateDepartment">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="field-label">Department Name</label>
                    <input type="text" class="form-control lp-input text-dark"
                           placeholder="e.g. Cardiology Unit" @bind-value="newDepartment.Name" required />
                </div>
                <div class="col-12 col-md-6">
                    <label class="field-label">Description / Medical Focus</label>
                    <input type="text" class="form-control lp-input text-dark"
                           placeholder="Brief summary of specialized services..." @bind-value="newDepartment.Description" />
                </div>
                <div class="col-12 col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn fw-semibold w-100"
                            style="background-color: #2BBFB3; color: #FFFFFF; border-radius: 8px; padding: 10px 14px; border: none;">
                        <i class="bi bi-save me-1"></i>Save Unit
                    </button>
                </div>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(formMessage))
        {
            <div class="mt-3 p-2" style="background-color: @(formSuccess ? "#D1FAF5" : "#FFE4E6"); color: @(formSuccess ? "#0D9488" : "#E11D48"); border-radius: 8px; font-size: 13px; font-weight: 500;">
                <i class="bi @(formSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>@formMessage
            </div>
        }
    </div>

    <!-- Departments List -->
    <div style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
        <h5 style="font-size: 15px; font-weight: 600; color: #1A1A2E; margin-bottom: 16px;">
            <i class="bi bi-list-stars me-2" style="color: #2BBFB3;"></i>Active Clinical Units Registry
        </h5>

        @if (departments == null)
        {
            <div class="text-center py-4"><div class="spinner-border" style="color: #2BBFB3;" role="status"></div></div>
        }
        else if (!departments.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-building-x" style="font-size: 48px; color: #D1D5DB;"></i>
                <p style="color: #6B7280; font-size: 14px; margin-top: 12px;">No departments created yet.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var dept in departments)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        @if (editingDeptId == dept.DepartmentId)
                        {
                            <!-- Inline edit card -->
                            <div style="background-color: #F0FDFB; border-radius: 10px; padding: 18px 20px; border: 2px solid #2BBFB3;">
                                <div class="mb-2">
                                    <label class="field-label">Department Name</label>
                                    <input type="text" class="form-control lp-input text-dark" @bind="editDept.Name" />
                                </div>
                                <div class="mb-3">
                                    <label class="field-label">Description</label>
                                    <input type="text" class="form-control lp-input text-dark" @bind="editDept.Description" />
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm fw-semibold flex-fill"
                                            style="background-color:#2BBFB3;color:#fff;border:none;border-radius:7px;"
                                            @onclick="SaveDeptEdit">
                                        <i class="bi bi-check2 me-1"></i>Save
                                    </button>
                                    <button class="btn btn-sm fw-semibold flex-fill"
                                            style="background-color:#F3F4F6;color:#6B7280;border:none;border-radius:7px;"
                                            @onclick="CancelDeptEdit">
                                        Cancel
                                    </button>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(editErrorMsg))
                                {
                                    <div style="font-size:12px;color:#E11D48;margin-top:8px;">@editErrorMsg</div>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Read-only card -->
                            <div style="background-color: #F9FAFB; border-radius: 10px; padding: 18px 20px; border: 1px solid #F3F4F6; border-left: 4px solid #2BBFB3;">
                                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                    <div>
                                        <div style="font-size: 15px; font-weight: 700; color: #2BBFB3; margin-bottom: 4px;">@dept.Name</div>
                                        <div style="font-size: 13px; color: #6B7280; line-height: 1.5;">
                                            @(string.IsNullOrWhiteSpace(dept.Description) ? "No description provided." : dept.Description)
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width: 38px; height: 38px; background-color: #E0F7F5; border-radius: 10px;">
                                        <i class="bi bi-building" style="color: #0D9488; font-size: 18px;"></i>
                                    </div>
                                </div>
                                <div class="mb-3" style="font-size: 12px; color: #9CA3AF;">
                                    <i class="bi bi-person-badge me-1" style="color: #2BBFB3;"></i>
                                    @(doctorCounts.TryGetValue(dept.DepartmentId, out var cnt) ? cnt : 0) doctor(s) assigned
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm fw-semibold flex-fill"
                                            style="border:1px solid #2BBFB3;color:#2BBFB3;background:#FFFFFF;border-radius:7px;font-size:12px;"
                                            @onclick="() => StartDeptEdit(dept)">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </button>
                                    <button class="btn btn-sm fw-semibold flex-fill"
                                            style="background-color:#FFE4E6;color:#E11D48;border:none;border-radius:7px;font-size:12px;"
                                            @onclick="() => RequestDeleteDept(dept.DepartmentId)">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </div>
                                @if (confirmDeleteDeptId == dept.DepartmentId)
                                {
                                    <div class="mt-2 p-2" style="background:#FFF5F5;border-radius:7px;border:1px solid #FECDD5;">
                                        <div style="font-size:12px;color:#991B1B;margin-bottom:6px;">
                                            Delete <strong>@dept.Name</strong>? This cannot be undone.
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm fw-semibold flex-fill"
                                                    style="background-color:#E11D48;color:#fff;border:none;border-radius:6px;font-size:11px;"
                                                    @onclick="() => ConfirmDeleteDept(dept.DepartmentId)">
                                                Confirm Delete
                                            </button>
                                            <button class="btn btn-sm flex-fill"
                                                    style="border:1px solid #E6EAF0;color:#6B7280;border-radius:6px;font-size:11px;background:#fff;"
                                                    @onclick="CancelDeleteDept">
                                                Cancel
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(deleteErrorMsg) && deleteErrorDeptId == dept.DepartmentId)
                                {
                                    <div style="font-size:12px;color:#E11D48;margin-top:6px;">@deleteErrorMsg</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .field-label { font-size: 12px; color: #6B7280; font-weight: 600; margin-bottom: 4px; display: block; }
    .lp-input { background-color: #F9FAFB; border: 1px solid #E6EAF0; border-radius: 8px; padding: 10px 14px; }
</style>

@code {
    private List<DepartmentDto>? departments;
    private DepartmentDto newDepartment = new();
    private string formMessage = "";
    private bool formSuccess = false;
    private Dictionary<int, int> doctorCounts = new();

    // Edit state
    private int? editingDeptId = null;
    private DepartmentDto editDept = new();
    private string editErrorMsg = "";

    // Delete confirm state
    private int? confirmDeleteDeptId = null;
    private int? deleteErrorDeptId = null;
    private string deleteErrorMsg = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        departments = await Http.GetFromJsonAsync<List<DepartmentDto>>("api/Admin/departments");
        var doctors = await Http.GetFromJsonAsync<List<DoctorDto>>("api/Admin/doctors");
        if (doctors != null)
            doctorCounts = doctors.GroupBy(d => d.DepartmentId).ToDictionary(g => g.Key, g => g.Count());
    }

    private async Task HandleCreateDepartment()
    {
        if (string.IsNullOrWhiteSpace(newDepartment.Name)) return;
        formMessage = "";
        var response = await Http.PostAsJsonAsync("api/Admin/departments", newDepartment);
        if (response.IsSuccessStatusCode)
        {
            formSuccess = true;
            formMessage = $"Department \"{newDepartment.Name}\" created successfully.";
            newDepartment = new();
            await LoadData();
        }
        else
        {
            formSuccess = false;
            formMessage = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(formMessage)) formMessage = "Failed to create department.";
        }
    }

    private void StartDeptEdit(DepartmentDto dept)
    {
        editingDeptId = dept.DepartmentId;
        editDept = new DepartmentDto { DepartmentId = dept.DepartmentId, Name = dept.Name, Description = dept.Description };
        editErrorMsg = "";
        confirmDeleteDeptId = null;
        deleteErrorMsg = "";
    }

    private void CancelDeptEdit()
    {
        editingDeptId = null;
        editErrorMsg = "";
    }

    private async Task SaveDeptEdit()
    {
        editErrorMsg = "";
        if (string.IsNullOrWhiteSpace(editDept.Name)) { editErrorMsg = "Name cannot be empty."; return; }
        var response = await Http.PutAsJsonAsync($"api/Admin/departments/{editDept.DepartmentId}", editDept);
        if (response.IsSuccessStatusCode)
        {
            editingDeptId = null;
            await LoadData();
        }
        else
        {
            editErrorMsg = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(editErrorMsg)) editErrorMsg = "Failed to update department.";
        }
    }

    private void RequestDeleteDept(int id)
    {
        confirmDeleteDeptId = id;
        deleteErrorMsg = "";
        deleteErrorDeptId = null;
        editingDeptId = null;
    }

    private void CancelDeleteDept()
    {
        confirmDeleteDeptId = null;
        deleteErrorMsg = "";
        deleteErrorDeptId = null;
    }

    private async Task ConfirmDeleteDept(int id)
    {
        deleteErrorMsg = "";
        var response = await Http.DeleteAsync($"api/Admin/departments/{id}");
        if (response.IsSuccessStatusCode)
        {
            confirmDeleteDeptId = null;
            await LoadData();
        }
        else
        {
            deleteErrorDeptId = id;
            deleteErrorMsg = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(deleteErrorMsg))
                deleteErrorMsg = "Cannot delete this department.";
            confirmDeleteDeptId = null;
        }
    }
}
