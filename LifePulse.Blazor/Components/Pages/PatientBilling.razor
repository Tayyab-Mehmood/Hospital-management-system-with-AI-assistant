@page "/patient/billing"
@using LifePulse.Shared
@inject HttpClient Http
@inject LifePulse.Blazor.CustomAuthStateProvider StateProvider

<PageTitle>My Invoices | LifePulse</PageTitle>

@if (!StateProvider.IsAuthenticated || StateProvider.Role != "Patient")
{
    <p style="color:#6B7280; text-align:center; padding-top: 40px;">
        Access denied. <a href="login" style="color:#2BBFB3;">Sign in</a>
    </p>
    return;
}

<div class="px-3 px-md-4 pt-4 pb-5">

    @* Header *@
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-size: clamp(20px, 5vw, 26px); font-weight: 700; color: #1A1A2E; margin: 0;">
                <i class="bi bi-receipt me-2" style="color: #2BBFB3;"></i>My Invoices
            </h2>
            <p style="font-size: 14px; color: #6B7280; margin: 4px 0 0 0;">
                Billing records generated by the hospital administration.
            </p>
        </div>

        @if (invoices != null && invoices.Any())
        {
            <div class="d-flex gap-2 flex-wrap">
                <div style="background-color: #FEE2E2; color: #E11D48; font-size: 13px; font-weight: 600; padding: 6px 14px; border-radius: 20px;">
                    <i class="bi bi-clock me-1"></i>Unpaid: @invoices.Count(i => i.PaymentStatus == "Unpaid")
                </div>
                <div style="background-color: #D1FAF5; color: #0D9488; font-size: 13px; font-weight: 600; padding: 6px 14px; border-radius: 20px;">
                    <i class="bi bi-check-circle me-1"></i>Paid: @invoices.Count(i => i.PaymentStatus == "Paid")
                </div>
            </div>
        }
    </div>

    @* Summary Cards *@
    @if (invoices != null && invoices.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="summary-card">
                    <div style="font-size: 12px; color: #6B7280; font-weight: 500;">Total Invoices</div>
                    <div style="font-size: 26px; font-weight: 800; color: #1A1A2E;">@invoices.Count</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="summary-card">
                    <div style="font-size: 12px; color: #6B7280; font-weight: 500;">Total Billed</div>
                    <div style="font-size: 22px; font-weight: 800; color: #1A1A2E;">$@invoices.Sum(i => i.TotalAmount).ToString("N2")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="summary-card">
                    <div style="font-size: 12px; color: #6B7280; font-weight: 500;">Amount Due</div>
                    <div style="font-size: 22px; font-weight: 800; color: #E11D48;">$@invoices.Where(i => i.PaymentStatus == "Unpaid").Sum(i => i.TotalAmount).ToString("N2")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="summary-card">
                    <div style="font-size: 12px; color: #6B7280; font-weight: 500;">Amount Paid</div>
                    <div style="font-size: 22px; font-weight: 800; color: #0D9488;">$@invoices.Where(i => i.PaymentStatus == "Paid").Sum(i => i.TotalAmount).ToString("N2")</div>
                </div>
            </div>
        </div>
    }

    @* Invoice List *@
    @if (invoices == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border" style="color: #2BBFB3; width: 2rem; height: 2rem;" role="status"></div>
        </div>
    }
    else if (!invoices.Any())
    {
        <div class="text-center py-5" style="background-color: #FFFFFF; border-radius: 12px; padding: 48px;">
            <i class="bi bi-receipt-cutoff" style="font-size: 52px; color: #D1D5DB;"></i>
            <p style="color: #6B7280; font-size: 15px; margin-top: 16px;">No invoices on record yet.</p>
            <small style="color: #9CA3AF;">Invoices are generated by the hospital after your visits.</small>
        </div>
    }
    else
    {
        @* Filter buttons *@
        <div class="d-flex gap-2 mb-4 flex-wrap">
            <button class="filter-btn @(activeFilter == "All" ? "filter-active" : "")" @onclick='() => activeFilter = "All"'>
                All (@invoices.Count)
            </button>
            <button class="filter-btn @(activeFilter == "Unpaid" ? "filter-active" : "")" @onclick='() => activeFilter = "Unpaid"'>
                <span style="width:8px;height:8px;border-radius:50%;background:#E11D48;display:inline-block;margin-right:6px;"></span>
                Unpaid (@invoices.Count(i => i.PaymentStatus == "Unpaid"))
            </button>
            <button class="filter-btn @(activeFilter == "Paid" ? "filter-active" : "")" @onclick='() => activeFilter = "Paid"'>
                <span style="width:8px;height:8px;border-radius:50%;background:#0D9488;display:inline-block;margin-right:6px;"></span>
                Paid (@invoices.Count(i => i.PaymentStatus == "Paid"))
            </button>
        </div>

        <div class="d-flex flex-column gap-3">
            @foreach (var inv in FilteredInvoices)
            {
                bool isPaid = inv.PaymentStatus == "Paid";
                <div class="invoice-card">
                    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                        <div class="d-flex align-items-start gap-3">
                            @* Invoice Icon *@
                            <div class="flex-shrink-0" style="width:48px;height:48px;background-color:@(isPaid ? "#D1FAF5" : "#FEE2E2");border-radius:10px;display:flex;align-items:center;justify-content:center;">
                                <i class="bi @(isPaid ? "bi-receipt-cutoff" : "bi-receipt")" style="font-size:22px;color:@(isPaid ? "#0D9488" : "#E11D48");"></i>
                            </div>
                            <div>
                                <div style="font-size:15px;font-weight:700;color:#1A1A2E;">Invoice #@inv.CheckoutId.ToString("D4")</div>
                                <div style="font-size:12px;color:#6B7280;margin-top:2px;">
                                    <i class="bi bi-calendar3 me-1"></i>@inv.CheckoutDate.ToString("dd MMM yyyy")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(inv.Notes))
                                {
                                    <div style="font-size:12px;color:#9CA3AF;margin-top:4px;">
                                        <i class="bi bi-chat-text me-1"></i>@inv.Notes
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div class="text-end">
                                <div style="font-size:20px;font-weight:800;color:#1A1A2E;">$@inv.TotalAmount.ToString("N2")</div>
                                <span style="font-size:12px;font-weight:600;background-color:@(isPaid ? "#D1FAF5" : "#FEE2E2");color:@(isPaid ? "#0D9488" : "#E11D48");padding:3px 12px;border-radius:20px;">
                                    @inv.PaymentStatus
                                </span>
                            </div>
                        </div>
                    </div>
                    @if (!isPaid)
                    {
                        <div class="mt-3 pt-3" style="border-top: 1px solid #F3F4F6;">
                            <div class="d-flex align-items-center gap-2" style="font-size:12px;color:#854D0E;background-color:#FEF9C3;padding:8px 12px;border-radius:8px;">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span>Payment pending. Please visit the billing desk or contact the hospital for payment options.</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
    .summary-card {
        background-color: #FFFFFF;
        border-radius: 12px;
        padding: 16px 18px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .invoice-card {
        background-color: #FFFFFF;
        border-radius: 12px;
        padding: 18px 20px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        border: 1px solid #F3F4F6;
        transition: box-shadow 0.2s;
    }
    .invoice-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.08); }
    .filter-btn {
        background-color: #FFFFFF;
        border: 1px solid #E6EAF0;
        border-radius: 20px;
        padding: 7px 16px;
        font-size: 13px;
        font-weight: 500;
        color: #6B7280;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s;
    }
    .filter-btn:hover { border-color: #2BBFB3; color: #2BBFB3; }
    .filter-active {
        background-color: #2BBFB3 !important;
        color: #FFFFFF !important;
        border-color: #2BBFB3 !important;
        font-weight: 600;
    }
</style>

@code {
    private List<CheckoutDto>? invoices;
    private string activeFilter = "All";

    private IEnumerable<CheckoutDto> FilteredInvoices =>
        invoices?.Where(i => activeFilter == "All" || i.PaymentStatus == activeFilter)
               .OrderByDescending(i => i.CheckoutDate)
        ?? Enumerable.Empty<CheckoutDto>();

    protected override async Task OnInitializedAsync()
    {
        if (!StateProvider.IsAuthenticated || StateProvider.Role != "Patient") return;
        int pid = StateProvider.UserId;
        try
        {
            invoices = await Http.GetFromJsonAsync<List<CheckoutDto>>($"api/Patient/{pid}/invoices");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Billing error: {ex.Message}");
            invoices = new();
        }
    }
}
