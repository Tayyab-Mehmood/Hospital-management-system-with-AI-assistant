@page "/patient/dashboard"
@using LifePulse.Shared
@inject HttpClient Http
@inject NavigationManager Nav
@inject LifePulse.Blazor.CustomAuthStateProvider StateProvider

<PageTitle>My Dashboard | LifePulse Patient Portal</PageTitle>

@if (!StateProvider.IsAuthenticated || StateProvider.Role != "Patient")
{
    <div class="text-center py-5">
        <p style="color: #6B7280;">Access denied. <a href="login" style="color: #2BBFB3;">Sign in as a patient</a>.</p>
    </div>
    return;
}

<div class="px-2 px-md-4 pt-3 pt-md-4 pb-5">

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold m-0" style="color: #1A1A2E; font-size: clamp(18px, 5vw, 24px);">
                Welcome back, @StateProvider.FullName 👋
            </h2>
            <small style="color: #6B7280;">@DateTime.Today.ToString("dddd, d MMMM yyyy") — Your health dashboard</small>
        </div>
        <div class="d-flex align-items-center gap-2"
             style="background-color: #FFFFFF; border: 1px solid #F3F4F6; padding: 4px 12px 4px 4px; border-radius: 30px; font-size: 13px;">
            <span class="d-flex align-items-center justify-content-center fw-bold"
                  style="width: 28px; height: 28px; background-color: #E0F7F5; color: #0D9488; border-radius: 50%; font-size: 11px;">
                @StateProvider.FullName.Substring(0, 1)
            </span>
            <span class="fw-semibold" style="color: #1A1A2E;">Patient</span>
        </div>
    </div>

    @* Summary Cards *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div style="background-color: #FFFFFF; border-radius: 12px; padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span style="font-size: 12px; color: #6B7280; font-weight: 500;">Total Appts</span>
                    <span class="d-flex align-items-center justify-content-center"
                          style="width: 36px; height: 36px; background-color: #E0F7F5; color: #0D9488; border-radius: 10px; font-size: 18px; flex-shrink: 0;">
                        <i class="bi bi-calendar-check-fill"></i>
                    </span>
                </div>
                <h2 style="font-size: 26px; font-weight: 700; color: #1A1A2E; margin: 0;">@(appointments?.Count ?? 0)</h2>
                <div style="font-size: 11px; color: #6B7280; margin-top: 4px;">Lifetime bookings</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div style="background-color: #FFFFFF; border-radius: 12px; padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span style="font-size: 12px; color: #6B7280; font-weight: 500;">Upcoming</span>
                    <span class="d-flex align-items-center justify-content-center"
                          style="width: 36px; height: 36px; background-color: #FEF9C3; color: #854D0E; border-radius: 10px; font-size: 18px; flex-shrink: 0;">
                        <i class="bi bi-clock-fill"></i>
                    </span>
                </div>
                <h2 style="font-size: 26px; font-weight: 700; color: #1A1A2E; margin: 0;">@(appointments?.Count(a => a.Status == "Scheduled") ?? 0)</h2>
                <div style="font-size: 11px; color: #6B7280; margin-top: 4px;">Scheduled</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div style="background-color: #FFFFFF; border-radius: 12px; padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span style="font-size: 12px; color: #6B7280; font-weight: 500;">Prescriptions</span>
                    <span class="d-flex align-items-center justify-content-center"
                          style="width: 36px; height: 36px; background-color: #FEE2E2; color: #E11D48; border-radius: 10px; font-size: 18px; flex-shrink: 0;">
                        <i class="bi bi-capsule-pill"></i>
                    </span>
                </div>
                <h2 style="font-size: 26px; font-weight: 700; color: #1A1A2E; margin: 0;">@(prescriptions?.Count(p => p.Status == "Active") ?? 0)</h2>
                <div style="font-size: 11px; color: #6B7280; margin-top: 4px;">Active</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div style="background-color: #FFFFFF; border-radius: 12px; padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span style="font-size: 12px; color: #6B7280; font-weight: 500;">Outstanding Bills</span>
                    <span class="d-flex align-items-center justify-content-center"
                          style="width: 36px; height: 36px; background-color: #FEF9C3; color: #854D0E; border-radius: 10px; font-size: 18px; flex-shrink: 0;">
                        <i class="bi bi-receipt"></i>
                    </span>
                </div>
                <h2 style="font-size: 26px; font-weight: 700; color: #1A1A2E; margin: 0;">@(invoices?.Count(i => i.PaymentStatus == "Unpaid") ?? 0)</h2>
                <div style="font-size: 11px; color: #6B7280; margin-top: 4px;">
                    <a href="patient/billing" style="color: #2BBFB3; text-decoration: none; font-weight: 600;">View invoices →</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Recent Appointments *@
        <div class="col-12 col-lg-7">
            <div style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 style="font-size: 16px; font-weight: 600; color: #1A1A2E; margin: 0;">Recent Appointments</h3>
                    <span @onclick='() => Nav.NavigateTo("patient/appointments")'
                          style="font-size: 12px; color: #2BBFB3; font-weight: 600; cursor: pointer; text-decoration: underline;">
                        View all
                    </span>
                </div>
                @if (appointments == null)
                {
                    <div class="text-center py-4"><div class="spinner-border" style="color: #2BBFB3; width: 1.5rem; height: 1.5rem;"></div></div>
                }
                else if (!appointments.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-calendar-x" style="font-size: 36px; color: #D1D5DB;"></i>
                        <p style="color: #6B7280; font-size: 14px; margin-top: 8px;">No appointments yet.</p>
                        <span @onclick='() => Nav.NavigateTo("patient/appointments")'
                              class="btn btn-sm" style="background-color: #2BBFB3; color: white; border-radius: 8px; cursor: pointer;">
                            Book your first appointment
                        </span>
                    </div>
                }
                else
                {
                    @foreach (var app in appointments.Take(4))
                    {
                        string statusColor = app.Status == "Completed" ? "#0D9488" : app.Status == "Cancelled" ? "#E11D48" : "#854D0E";
                        string statusBg = app.Status == "Completed" ? "#D1FAF5" : app.Status == "Cancelled" ? "#FFE4E6" : "#FEF9C3";
                        <div class="d-flex align-items-center justify-content-between p-3 mb-2 flex-wrap gap-2"
                             style="background-color: #F4F6F9; border-radius: 8px;">
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-family: monospace; font-weight: 700; color: #2BBFB3; font-size: 12px; white-space: nowrap;">
                                    @app.AppointmentDate.ToString("dd MMM")
                                </span>
                                <div>
                                    <div style="font-size: 14px; font-weight: 600; color: #1A1A2E;">@app.DoctorName</div>
                                    <small style="color: #6B7280; font-size: 12px;">@app.DepartmentName</small>
                                </div>
                            </div>
                            <span style="font-size: 11px; font-weight: 600; background-color: @statusBg; color: @statusColor; padding: 3px 10px; border-radius: 20px;">
                                @app.Status
                            </span>
                        </div>
                    }
                }
            </div>
        </div>

        @* Current Prescriptions *@
        <div class="col-12 col-lg-5">
            <div style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 style="font-size: 16px; font-weight: 600; color: #1A1A2E; margin: 0;">Current Medications</h3>
                    <span @onclick='() => Nav.NavigateTo("patient/prescriptions")'
                          style="font-size: 12px; color: #2BBFB3; font-weight: 600; cursor: pointer; text-decoration: underline;">
                        View all
                    </span>
                </div>
                @if (prescriptions == null)
                {
                    <div class="text-center py-4"><div class="spinner-border" style="color: #2BBFB3; width: 1.5rem; height: 1.5rem;"></div></div>
                }
                else if (!prescriptions.Where(p => p.Status == "Active").Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-capsule" style="font-size: 36px; color: #D1D5DB;"></i>
                        <p style="color: #6B7280; font-size: 14px; margin-top: 8px;">No active prescriptions.</p>
                    </div>
                }
                else
                {
                    @foreach (var rx in prescriptions.Where(p => p.Status == "Active").Take(4))
                    {
                        <div class="p-3 mb-2" style="background-color: #F4F6F9; border-radius: 8px; border-left: 3px solid #2BBFB3;">
                            <div style="font-size: 14px; font-weight: 600; color: #1A1A2E;">@rx.MedicineName</div>
                            <small style="color: #6B7280;">@rx.Dosage · @rx.Frequency</small>
                            <div style="font-size: 11px; color: #9CA3AF; margin-top: 2px;">By @rx.DoctorName</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<AppointmentDto>? appointments;
    private List<PrescriptionDto>? prescriptions;
    private List<CheckoutDto>? invoices;

    protected override async Task OnInitializedAsync()
    {
        if (!StateProvider.IsAuthenticated || StateProvider.Role != "Patient") return;
        int pid = StateProvider.UserId;
        try
        {
            appointments = await Http.GetFromJsonAsync<List<AppointmentDto>>($"api/Patient/{pid}/appointments");
            prescriptions = await Http.GetFromJsonAsync<List<PrescriptionDto>>($"api/Patient/{pid}/prescriptions");
            invoices = await Http.GetFromJsonAsync<List<CheckoutDto>>($"api/Patient/{pid}/invoices");
        }
        catch (Exception ex) { Console.WriteLine($"Patient dashboard error: {ex.Message}"); }
    }
}
