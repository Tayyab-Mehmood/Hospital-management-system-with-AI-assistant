@page "/admin/patients"
@using LifePulse.Shared
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Patients | LifePulse</PageTitle>

<div class="container-fluid px-2 px-md-4">

    <!-- Page Header -->
    <div class="mb-4 no-print">
        <h1 style="font-size: clamp(20px,5vw,26px); font-weight: 700; color: #1A1A2E; margin: 0;">Patient Registry Center</h1>
            <p style="font-size: 14px; color: #6B7280; margin: 2px 0 0 0;">
                View and manage registered patient profiles. Patients self-register via the Patient Portal.
            </p>
    </div>

    <!-- Info Banner -->
    <div class="mb-4 no-print d-flex align-items-center gap-3 p-3"
         style="background-color: #EFF6FF; border-radius: 10px; border-left: 4px solid #2BBFB3;">
        <i class="bi bi-info-circle-fill" style="color: #2BBFB3; font-size: 20px; flex-shrink: 0;"></i>
        <div>
            <span style="font-size: 14px; font-weight: 600; color: #1A1A2E;">Read-Only Registry</span>
            <p style="font-size: 13px; color: #6B7280; margin: 0;">
                Patient profiles are created through self-registration on the Patient Portal. Admins can search and delete records only.
            </p>
        </div>
    </div>

    <!-- Patients Table Card -->
    <div style="background-color: #FFFFFF; border-radius: 12px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">

        <div class="row g-3 justify-content-between align-items-center mb-4 no-print">
            <div class="col-12 col-sm-6 col-md-5" style="position: relative;">
                <input type="text" class="form-control text-dark"
                       style="background-color: #F3F4F6; border: none; border-radius: 24px; padding: 10px 18px 10px 40px;"
                       placeholder="Search registered patients..."
                       @bind="searchQuery" @bind:event="oninput" />
                <i class="bi bi-search" style="position: absolute; left: 24px; top: 12px; color: #9CA3AF;"></i>
            </div>
            <div class="col-12 col-sm-auto text-sm-end">
                <button class="btn fw-semibold w-100"
                        style="border: 1px solid #2BBFB3; color: #2BBFB3; background: #FFFFFF; border-radius: 20px; padding: 6px 16px; font-size: 13px;"
                        @onclick="PrintReport">
                    <i class="bi bi-printer me-1"></i> Print Information Report
                </button>
            </div>
        </div>

        <!-- Print Header -->
        <div class="print-only mb-4 text-center border-bottom pb-3">
            <h3 style="color: #1A1A2E; font-weight: 700; margin: 0;">LIFEPULSE CLINICAL HEALTHCARE NETWORK</h3>
            <p style="color: #6B7280; margin: 4px 0 0 0; font-size: 14px; font-weight: 600;">Official Patient Registry Summary Ledger Report</p>
            <small style="color: #9CA3AF;">Generated Date: @DateTime.Now.ToString("f")</small>
        </div>

        @if (filteredPatients == null)
        {
            <div class="text-center py-4"><div class="spinner-border" style="color: #2BBFB3;" role="status"></div></div>
        }
        else if (!filteredPatients.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-person-x" style="font-size: 48px; color: #D1D5DB;"></i>
                <p style="color: #6B7280; font-size: 14px; margin-top: 12px;">
                    @(string.IsNullOrWhiteSpace(searchQuery) ? "No patients have registered yet." : "No patients match your search.")
                </p>
            </div>
        }
        else
        {
            <!-- Summary chips -->
            <div class="d-flex gap-2 mb-3 flex-wrap no-print">
                <span style="font-size: 13px; font-weight: 600; background-color: #E0F7F5; color: #0D9488; padding: 4px 14px; border-radius: 20px;">
                    <i class="bi bi-people-fill me-1"></i>@patients!.Count Total Patients
                </span>
                <span style="font-size: 13px; font-weight: 600; background-color: #F3F4F6; color: #6B7280; padding: 4px 14px; border-radius: 20px;">
                    Showing @filteredPatients.Count() results
                </span>
            </div>

            <div class="table-responsive">
                <table class="table align-middle m-0" style="width: 100%; min-width: 580px;">
                    <thead>
                        <tr style="background-color: #F9FAFB; border-bottom: 2px solid #F3F4F6;">
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Full Patient Name</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Contact Info</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Gender</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px;">Date of Birth</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px; text-align: center;">Blood Group</th>
                            <th style="font-size: 13px; font-weight: 600; color: #6B7280; padding: 12px; text-align: center;" class="no-print">Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pat in filteredPatients)
                        {
                            <tr style="border-bottom: 1px solid #F3F4F6;">
                                <td style="padding: 14px 12px;">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="d-flex align-items-center justify-content-center fw-bold"
                                             style="width: 36px; height: 36px; border-radius: 50%; background-color: #E0F7F5; color: #0D9488; font-size: 13px; flex-shrink: 0;">
                                            @pat.FirstName.Substring(0,1)@pat.LastName.Substring(0,1)
                                        </div>
                                        <div>
                                            <span style="font-size: 14px; font-weight: 700; color: #1A1A2E; display: block;">@pat.FirstName @pat.LastName</span>
                                            <small style="color: #9CA3AF; font-size: 11px; font-family: monospace;">@@@pat.Username</small>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-size: 13px; color: #1A1A2E; padding: 14px 12px;">
                                    <div style="font-weight: 500;">@pat.Email</div>
                                    <small style="color: #6B7280; font-size: 12px;">@pat.Phone</small>
                                </td>
                                <td style="font-size: 14px; color: #1A1A2E; padding: 14px 12px;">@pat.Gender</td>
                                <td style="font-size: 14px; color: #1A1A2E; padding: 14px 12px;">@pat.DateOfBirth.ToString("yyyy-MM-dd")</td>
                                <td style="padding: 14px 12px; text-align: center;">
                                    @if (!string.IsNullOrWhiteSpace(pat.BloodGroup))
                                    {
                                        <span style="font-size: 11px; font-weight: 700; background-color: #FFE4E6; color: #E11D48; padding: 4px 10px; border-radius: 6px;">
                                            @pat.BloodGroup
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: #9CA3AF; font-size: 12px;">—</span>
                                    }
                                </td>
                                <td style="padding: 14px 12px; text-align: center;" class="no-print">
                                    @if (confirmDeleteId == pat.PatientId)
                                    {
                                        <div class="d-flex gap-1 justify-content-center flex-wrap">
                                            <button class="btn btn-sm fw-semibold px-2"
                                                    style="background-color: #E11D48; color: #FFFFFF; border-radius: 6px; border: none; font-size: 11px;"
                                                    @onclick="() => ConfirmDelete(pat.PatientId)">
                                                Confirm
                                            </button>
                                            <button class="btn btn-sm px-2"
                                                    style="border: 1px solid #E6EAF0; color: #6B7280; border-radius: 6px; font-size: 11px; background: white;"
                                                    @onclick="CancelDelete">
                                                Cancel
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm fw-semibold px-3"
                                                style="background-color: #FFE4E6; color: #E11D48; border-radius: 6px; border: none; font-size: 12px;"
                                                @onclick="() => RequestDelete(pat.PatientId)">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .print-only { display: none; }
    @@media print {
        .no-print { display: none !important; visibility: hidden !important; }
        body, html, main, .content { background: #FFFFFF !important; color: #000000 !important; margin: 0 !important; padding: 0 !important; }
        .print-only { display: block !important; }
        table { width: 100% !important; border-collapse: collapse !important; }
        th { background-color: #F3F4F6 !important; color: #000000 !important; border: 1px solid #DDDDDD !important; padding: 8px !important; }
        td { background: #FFFFFF !important; color: #000000 !important; border: 1px solid #DDDDDD !important; padding: 8px !important; }
    }
</style>

@code {
    private List<PatientDto>? patients;
    private string searchQuery = "";
    private int? confirmDeleteId = null;

    protected override async Task OnInitializedAsync() => await LoadPatients();

    private async Task LoadPatients() =>
        patients = await Http.GetFromJsonAsync<List<PatientDto>>("api/Admin/patients");

    private IEnumerable<PatientDto>? filteredPatients =>
        string.IsNullOrWhiteSpace(searchQuery) ? patients :
        patients?.Where(p =>
            $"{p.FirstName} {p.LastName}".Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            (p.Phone ?? "").Contains(searchQuery) ||
            (p.Email ?? "").Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private void RequestDelete(int id) => confirmDeleteId = id;
    private void CancelDelete() => confirmDeleteId = null;

    private async Task ConfirmDelete(int id)
    {
        var response = await Http.DeleteAsync($"api/Admin/patients/{id}");
        if (response.IsSuccessStatusCode)
        {
            confirmDeleteId = null;
            await LoadPatients();
        }
    }

    private async Task PrintReport() => await JS.InvokeVoidAsync("window.print");
}
